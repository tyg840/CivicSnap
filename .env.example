# API_KEY: Required for live Qianfan OpenAI-compatible model API calls.
API_KEY="MY_API_KEY"

# APP_ID: Required Qianfan app id header for live issue photo analysis.
APP_ID="MY_APP_ID"

# APP_URL: The URL where this applet is hosted.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="https://civicsnap.ca"

# VITE_APP_URL: Public browser URL used for Supabase email verification and OAuth redirects.
VITE_APP_URL="https://civicsnap.ca"

# Supabase Auth:
# Use Project Settings -> API values from your Supabase project.
VITE_SUPABASE_URL="MY_SUPABASE_PROJECT_URL"
VITE_SUPABASE_ANON_KEY="MY_SUPABASE_ANON_PUBLIC_KEY"

# Tencent Cloud COS storage:
# Required to save report images and report-details.json to COS.
# Object layout: <UID>/<REPORT_ID>/files/* and <UID>/<REPORT_ID>/report-details.json
TENCENT_SECRET_ID="MY_TENCENT_SECRET_ID"
TENCENT_SECRET_KEY="MY_TENCENT_SECRET_KEY"
TENCENT_COS_BUCKET="MY_BUCKET_NAME_WITH_APPID"
TENCENT_COS_REGION="ap-toronto"

# Optional: public CDN or COS bucket base URL, without a trailing slash.
# If omitted, stored image/detail URLs are returned as cos://bucket/key references.
TENCENT_COS_PUBLIC_BASE_URL="https://MY_BUCKET_NAME_WITH_APPID.cos.ap-toronto.myqcloud.com"

# Toronto Open311 / 311 API test script:
# Start with the test endpoint. Production can create real City service requests.
TORONTO_311_ENV="test"
TORONTO_311_JURISDICTION_ID="toronto.ca"
TORONTO_311_API_KEY="MY_TORONTO_311_API_KEY"
TORONTO_311_SERVICE_CODE="SERVICE_CODE_FROM_SERVICES"
TORONTO_311_ADDRESS="100 Queen St W, Toronto, ON"
TORONTO_311_DESCRIPTION="Test issue description for the Toronto Open311 test endpoint."
TORONTO_311_EMAIL="citizen@example.com"
TORONTO_311_FIRST_NAME="Test"
TORONTO_311_LAST_NAME="Citizen"
TORONTO_311_PHONE="416-555-0100"
# Optional JSON object for service-specific required metadata, for example:
# TORONTO_311_ATTRIBUTES='{"attribute_code":"value"}'
TORONTO_311_ATTRIBUTES=""
# Required, together with the script --send flag, before the script submits.
TORONTO_311_SEND="false"
# Required only when TORONTO_311_ENV is production.
TORONTO_311_CONFIRM_PRODUCTION="false"
