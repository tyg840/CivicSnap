{
  "name": "civic-snap",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "bun run server.ts",
    "build": "vite build && NODE_ENV=production bun build --target=node --format=esm --sourcemap=linked --external vite --outdir=dist --entry-naming=server.js server.ts",
    "start": "NODE_ENV=production bun run dist/server.js",
    "clean": "bun -e \"import { rmSync } from 'node:fs'; for (const path of ['dist', 'server.js', 'server.js.map']) rmSync(path, { recursive: true, force: true });\"",
    "lint": "tsc --noEmit",
    "open311:test": "bun run script/toronto-open311-test.ts"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.108.1",
    "@tailwindcss/vite": "^4.1.14",
    "@types/leaflet": "^1.9.21",
    "@types/leaflet.markercluster": "^1.5.6",
    "@vitejs/plugin-react": "^5.0.4",
    "cos-nodejs-sdk-v5": "^2.15.4",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "leaflet": "^1.9.4",
    "leaflet.markercluster": "^1.5.3",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "openai": "^6.39.1",
    "react": "^19.0.1",
    "react-dom": "^19.0.1",
    "react-leaflet": "^5.0.0",
    "vite": "^6.2.3"
  },
  "devDependencies": {
    "@types/node": "^22.14.0",
    "autoprefixer": "^10.4.21",
    "esbuild": "^0.25.0",
    "tailwindcss": "^4.1.14",
    "typescript": "~5.8.2",
    "@types/express": "^4.17.21",
    "@types/bun": "latest"
  }
}
